# ─── NewsCraft AI — Production Environment Variables ─────────────────────────
# Copy this file to `.env` ONLY for local testing of the production build.
# On Render, set these variables directly in the Environment Variables dashboard.
# NEVER commit a filled-in .env file to git.

# ── Runtime ───────────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_strong_random_key

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase PostgreSQL — use the "Session mode" connection string (port 5432)
# Found in: Supabase dashboard > Project Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard > Project Settings > API
SUPABASE_URL=https://[YOUR_PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=newscraft-clippings

# ── AI Engine ─────────────────────────────────────────────────────────────────
# Groq key (starts with gsk_) or xAI Grok key
GROK_API_KEY=gsk_...

# ── CORS / Frontend URL ───────────────────────────────────────────────────────
# Set to your deployed frontend URL (Vercel, Netlify, etc.)
# Also accepted as comma-separated list: CORS_ORIGINS=https://app.com,https://www.app.com
FRONTEND_URL=https://your-frontend.vercel.app

# ── Stripe (optional — only needed for subscriptions) ─────────────────────────
STRIPE_API_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email / SMTP (optional) ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
EMAILS_FROM_EMAIL=noreply@newscraft.ai
